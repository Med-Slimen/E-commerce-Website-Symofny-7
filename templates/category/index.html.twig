{% extends 'base.html.twig' %}

{% block title %}Categories!{% endblock %}

{% block body %}
    <div class="container">
        <h1>Categories</h1>
        <a href="{{ path('app_category_new') }}" class="btn btn-primary mb-3">Create new Category</a>
        {% include 'layouts/_flash_message.html.twig' %}
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for category in categories %}
                    <tr>
                        <td>{{ category.id }}</td>
                        <td>{{ category.name }}</td>
                        <td>
                            <a href="{{ path('app_category_update', {'id': category.id}) }}" class="btn btn-secondary">Edit</a>
                            <a onclick="return confirm('Are you sure you want to delete this category?');" href="{{ path('app_category_delete', {'id': category.id}) }}" class="btn btn-danger">Supprimer</a>
                            {# Add delete button if needed #}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
