{% extends 'base.html.twig' %}

{% block title %}Hello HomeController!{% endblock %}

{% block body %}
<div class="container"><br>
    
    <div class="row">
        <div class="col-md-6">
            <img src="{{ asset('uploads/images/' ~ product.image) }}" class="card-img-top object-fit-cover" width="250px" height="400px" alt="{{ product.name }}">
        </div>
        <div class="col-md-6">
            <h1>{{ product.name }}</h1>
            <h3>Description</h3>
            <p>{{ product.description }}</p>
            <h4>{{ product.price }} $</h4>
            <a href="#" class="btn btn-success">Add to Cart</a>
        </div>
    </div>
    <h2>Last Added Products</h2>
    <div class="row">
        {% for product in latestProducts %}
            <div class="col-md-4">
                <div class="card mb-4 shadow-sm">
                    <img src="{{ asset('uploads/images/' ~ product.image) }}" class="card-img-top object-fit-cover" width="250px" height="400px" alt="{{ product.name }}">
                    <div class="card-body">
                        <a  style="text-decoration: none;color:green;" href="{{ path('app_home_product_show', {'id': product.id}) }}">
                            <h5 class="card-title ">{{ product.name }}</h5>
                        </a>
                        <p class="card-text">{{ product.description | slice(0, 100) }}...</p>
                        <h3>{{ product.price }} $</h3>
                        <a href="{{ path('app_cart_new', {'id': product.id}) }}" class="btn btn-success">Add to Cart</a>
                    </div>
                </div>
            </div>
        {% else %}
            <p>No products found.</p>
        {% endfor %}
    </div>
</div>
{% endblock %}
