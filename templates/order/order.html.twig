{% extends 'base.html.twig' %}

{% block title %}Order
{% endblock %}

{% block body %}
	<div class="container mt-5">
		<h1>Here is the list of orders</h1>
        {% include 'layouts/_flash_message.html.twig' %}
		{% for order in orders %}
			<h3>Order n:
				{{ order.id }}</h3>
                {% if order.isCompleted == true %}
                <span class="badge bg-success">Order Delivered : {{ order.createdAt|date('d/m/Y') }}</span>
                {% else %}
                <span class="badge bg-warning">Order Not Delivered : {{ order.createdAt|date('d/m/Y') }}</span>
                {% endif %}
			<h5>Information about the order:</h5>
			<table class="table table-bordered">
				<thead>
					<tr>
						<th scope="col">First Name</th>
						<th scope="col">Last Name</th>
						<th scope="col">Phone</th>
						<th scope="col">Address</th>
						<th scope="col">City</th>
					</tr>
				</thead>
				<tbody>

					<tr>
						<td>{{ order.firstName }}</td>
						<td>{{ order.lastName }}</td>
						<td>{{ order.phone }}</td>
						<td>{{ order.adresse }}</td>
						<td>{{ order.city.name }}</td>
					</tr>

				</tbody>
			</table>
		
		<h5>Products in the order:</h5>
		<table class="table table-bordered">
			<thead>
				<tr>
                    <th scope="col">Product Image</th>
					<th scope="col">Product Name</th>
                    <th scope="col">Description</th>
					<th scope="col">Price</th>
					<th scope="col">Quantity</th>
					<th scope="col">Total Price</th>
				</tr>
			</thead>
			<tbody>
				{% for product in order.orderProducts %}
					<tr>
                        <td><img src="{{ asset('uploads/images/' ~ product.product.image) }}" alt="{{ product.product.name }}" width="150"></td>
						<td>{{ product.product.name }}</td>
                        <td>{{ product.product.description|slice(0, 100) }}...</td>
						<td>{{ product.product.price }} $</td>
						<td>{{ product.qte }}</td>
						<td>{{ product.product.price * product.qte }} $</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>
        <h5>Shipping Cost: {{ order.city.shippingCost }}$</h5>
        <h5>Total Order Price: {{ order.totalPrice + order.city.shippingCost }}$</h5>
        <a href="{{ path('app_bill', {'id': order.id}) }}" class="btn btn-primary">View Bill</a>
         {% if order.isCompleted != true %}
        <a href="{{ path('app_order_update_is_completed', {'id': order.id}) }}" class="btn btn-success">Mark as Delivered</a>
        {% endif %}
        <a onclick="return confirm('Are you sure you want to delete this order?')" href="{{ path('app_order_remove', {'id': order.id}) }}" class="btn btn-danger">Delete Order</a>
        <hr>
        {% endfor %}
        {{ knp_pagination_render(orders,'layouts/pagination_template.html.twig') }}
	</div>
{% endblock %}

