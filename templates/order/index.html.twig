{% extends 'base.html.twig' %}

{% block title %}Hello OrderController!{% endblock %}

{% block body %}
<div class="container">
    <div class="row">
        <div class="col-8">
            <h1>Checkout</h1>
            {{ form_start(form) }}
            {{form_widget(form)}}
                <button class="btn btn-primary">Submit</button>
            {{ form_end(form) }}
        </div>
        <div class="col-4"><br><br><br><br>
        <h3 class="">Order Summary</h3><br>
            <h4 id="">Total :</h4>
            <h4 id="card-price">{{ total }}<span > $</span></h4>
            <h4 id="">Shipping Cost:</h4>
            <h4 class=""> <span id="shipping-cost"></span> $</h4>
            <h4 id="">Total with Shipping: </h4>
            <h4><span id="total-price"></span> $</h4>
        </div>
    </div>
</div>
<script src="https://code.jquery.com/jquery-4.0.0.min.js" integrity="sha256-OaVG6prZf4v69dPg6PhVattBXkcOWQB62pdZ3ORyrao=" crossorigin="anonymous"></script>
<script>
    $(document).ready(function() {
        const citySelector=$('#order_city');
        const cityValue=citySelector.val();
        const url='http://127.0.0.1:8080/city/' + cityValue + '/shipping/cost';
        function ajaxRequest(url){
            $.ajax({
                url: url,
                type: 'GET',
                success: function(data) {
                    const response = JSON.parse(data);
                    if (response.status === 200) {
                        $('#shipping-cost').text(response.content);
                        const cardPrice= parseInt($('#card-price').text());
                        const shippingCost= parseInt($('#shipping-cost').text());
                        $('#total-price').text(cardPrice + shippingCost);
                    } else {
                        console.error('Error fetching shipping cost:', response.message);
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Error fetching shipping cost:', error);
                }
            });
        }
        ajaxRequest(url);
        citySelector.on('change', function() {
                const cityValue=$(this).val();
                const urlUpdated='http://127.0.0.1:8080/city/' + cityValue + '/shipping/cost';
                ajaxRequest(urlUpdated);
            });
    });
</script>
{% endblock %}
